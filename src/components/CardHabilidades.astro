---
interface Props {
	title: string;
	description: string;
	href?: string;
	ctaText?: string;
	imageSrc?: string;
	imageAlt?: string;
}

const {
	title,
	description,
	href = "Github.com",
	ctaText = "Ver más",
	imageSrc,
	imageAlt = title,
} = Astro.props;
---

<article
	class="group/card relative flex h-full flex-col items-center gap-1.5 overflow-visible px-0.5 py-1 text-center sm:gap-2 sm:py-1.5"
>
	<div class="relative flex flex-col items-center">
		<!-- Globo / tooltip encima del ícono -->
		<div
			class="pointer-events-none absolute bottom-full left-1/2 z-30 mb-1.5 flex w-max max-w-[min(14rem,calc(100vw-2rem))] -translate-x-1/2 translate-y-1 scale-95 flex-col items-center opacity-0 transition-all duration-200 ease-out group-hover/card:pointer-events-auto group-hover/card:translate-y-0 group-hover/card:scale-100 group-hover/card:opacity-100 group-focus-within/card:translate-y-0 group-focus-within/card:scale-100 group-focus-within/card:opacity-100 sm:mb-2"
			role="tooltip"
		>
			<div
				class="rounded-xl bg-zinc-950/30 backdrop-blur-md px-3 py-2 text-center text-[10px] leading-snug text-text-main shadow-[0_8px_30px_-6px_rgba(0,0,0,0.65)] ring-1 ring-white/15 sm:text-xs "
			>
				{description}
			</div>
			<!-- Cola del globo -->
<div class="relative h-2 w-4 overflow-hidden">
    <div class="absolute left-1/2 top-0 h-3 w-3 -translate-x-1/2 -translate-y-1/2 rotate-45 bg-zinc-950/30 backdrop-blur-md ring-1 ring-white/15">
    </div>
</div>
		</div>

		{imageSrc ? (
			<img
				src={imageSrc}
				alt={imageAlt}
				class="h-12 w-12 shrink-0 object-contain transition duration-300 group-hover/card:scale-105 sm:h-14 sm:w-14"
			/>
		) : (
			<div
				class="h-12 w-12 shrink-0 text-white/95 transition duration-300 group-hover/card:scale-105 sm:h-14 sm:w-14 [&_svg]:block [&_svg]:h-full [&_svg]:w-full"
				aria-hidden="true"
			>
				<slot name="icon" />
			</div>
		)}
	</div>

	<p class="subtitle max-w-[12ch] text-xs font-medium leading-tight text-text-main sm:max-w-[14ch] sm:text-sm">
		{title}
	</p>

	<a
		href={href}
		class="group/link inline-flex items-center gap-0.5 text-[10px] font-medium text-text-muted transition-colors duration-200 hover:text-red-400 sm:text-xs "
	>
		<span>{ctaText}</span>
		<span class="absolute -bottom-0.5 left-0 h-px w-0 bg-red-400 transition-all duration-300 group-hover/link:w-full"></span>
	</a>
</article>
